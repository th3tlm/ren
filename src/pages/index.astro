---
<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Renaissance Tlemcen | L'Art de l'Exception</title>

    <!-- Fonts & Icons -->
    <link
        href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Montserrat:wght@200;400;600&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
</head>

<body>

    <div id="cursor"></div>
    <div id="cursor-blur"></div>

    <header id="navbar">
        <div class="logo"><img src="/images/Screenshot_2026-03-09_132546-removebg-preview.png" alt="Logo"></div>
        <nav>
            <ul>
                <li><a href="#about">Héritage</a></li>
                <li><a href="#services">Expériences</a></li>
                <li><a href="#offers">Offres SIAHA</a></li>
                <li><a href="#rooms">Suites</a></li>
                <li><a href="#explore">Explore</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </nav>
    </header>

    <main>
        <section class="hero">
            <div class="hero-bg" id="hero-bg"></div>
            <div data-aos="zoom-out">
                <h1>Renaissance</h1>
                <p style="text-align:center; letter-spacing:8px; opacity:0.8;">L'EXCEPTION TLEMCÉNIENNE</p>
            </div>
        </section>

        <!-- HISTOIRE -->
        <section id="about">
            <div class="about-grid">
                <div class="about-text" data-aos="fade-right">
                    <h2 style="text-align: left;" class="section-title">Une Histoire de Prestige</h2>
                    <p>Nichée sur le plateau majestueux de Lalla Setti, notre demeure est un hommage vibrant à
                        l'architecture andalouse, mariant avec audace l'héritage millénaire de Tlemcen et le luxe
                        contemporain.</p>
                    <p>Chaque arcade et chaque mosaïque ont été pensées pour offrir une expérience hors du temps, où le
                        confort moderne rencontre la noblesse des traditions algériennes.</p>
                </div>
                <div class="about-gallery" data-aos="fade-left">
                    <img src="/images/Lobby_Seating_Night_7706.jpg" alt="Extérieur Nuit">
                    <img src="/images/Details_Suite_Views_9447.jpg" alt="Vue Suite">
                    <img src="/images/Exterior_Night_7462.jpg" style="grid-column: span 2;" alt="Lobby">
                </div>
            </div>
        </section>

        <!-- SERVICES -->
        <section id="services" style="padding-right: 0; padding-left: 0;">
            <h2 class="section-title" data-aos="fade-up">Nos Expériences</h2>

            <div class="scroll-indicator">
                <i class="fas fa-chevron-left"></i> SWIPE <i class="fas fa-chevron-right"></i>
            </div>

            <div class="services-scroll-container" data-aos="fade-up">
                <div class="service-card-wide">
                    <img src="/images/Spa_Massage_Room_0027.jpg" alt="Spa">
                    <div class="service-card-content">
                        <h3>Spa & Bien-être</h3>
                        <p>Hammam traditionnel et rituels de soins ancestraux pour une sérénité absolue.</p>
                    </div>
                </div>
                <div class="service-card-wide">
                    <img src="/images/Restaurant_Arabesque_General_Seating_0019.jpg" alt="Gastronomie">
                    <div class="service-card-content">
                        <h3>Gastronomie</h3>
                        <p>Découvrez nos 5 tables d'exception, entre saveurs locales et haute cuisine internationale.
                        </p>
                    </div>
                </div>
                <div class="service-card-wide">
                    <img src="/images/Gym_0002.jpg" alt="Fitness">
                    <div class="service-card-content">
                        <h3>Fitness & Sport</h3>
                        <p>Piscine et équipements de pointe avec une vue panoramique sur la ville.</p>
                    </div>
                </div>
                <div class="service-card-wide">
                    <img src="/images/Social_Ballroom_Setup_0004.jpg" alt="Event">
                    <div class="service-card-content">
                        <h3>Mariages & Gala</h3>
                        <p>Des espaces majestueux et un service sur-mesure pour vos événements de prestige.</p>
                    </div>
                </div>
                <div class="service-card-wide">
                    <img src="/images/Patio_Lounge_Exterior_Lifestyle_7904.jpg" alt="Lounge">
                    <div class="service-card-content">
                        <h3>Lounge Extérieur</h3>
                        <p>Détendez-vous sur notre terrasse avec une vue imprenable sur le coucher du soleil.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- OFFRES -->
        <section id="offers">
            <h2 class="section-title" data-aos="fade-up">Offres SIAHA 2026</h2>
            <div class="offers-grid">
                <div class="offer-card" data-aos="zoom-in">
                    <div style="position: relative;">
                        <img src="/images/Guestroom_Standard_King_9811.jpg" alt="Offre">
                        <span
                            style="position: absolute; top: 10px; right: 10px; background: var(--cream); color: var(--bg); padding: 5px 12px; font-size: 9px; font-weight: bold;">SIGNATURE</span>
                    </div>
                    <h3>Réservez 3 nuitées, la 4ᵉ offerte</h3>
                    <div class="offer-details">
                        <p style="font-style: italic;">"Un séjour d’exception, entre relaxation absolue et découvertes
                            locales raffinées."</p>
                        <ul style="list-style:none; margin: 15px 0;">
                            <li>• 4ème nuit offerte</li>
                            <li>• Une balade touristique ou une visite guidée à Tlemcen.</li>
                            <li>• Accès Spa , Hemmem , Sauna et GYM offert </li>
                            <li>• Accès au parc d’attractions offert </li>
                        </ul>
                        <button class="btn-offer">Réserver</button>
                    </div>
                </div>

                <div class="offer-card" data-aos="zoom-in" data-aos-delay="200">
                    <img src="/images/436414.jpg" alt="Famille">
                    <h3>Family Offer</h3>
                    <div class="offer-details">
                        <p style="font-style: italic;">"Des moments précieux à partager en famille."</p>
                        <ul style="list-style:none; margin: 15px 0;">
                            <li>• Kids Eat for Free</li>
                            <li>• -50% sur la 2ème chambre</li>
                            <li>• Accès au Spa et salle de sport</li>
                            <li>• Late check-out jusqu’à 14h</li>
                        </ul>
                        <button class="btn-offer">Découvrir</button>
                    </div>
                </div>
                <div class="offer-card" data-aos="zoom-in" data-aos-delay="400">
                    <img src="/images/Patio_Lounge_Exterior_Lifestyle_7904.jpg" alt="Escale">
                    <h3>Early Bird</h3>
                    <div class="offer-details">
                        <p style="font-style: italic;">Réservez tôt, Economisez plus.</p>
                        <ul style="list-style:none; margin: 15px 0;">
                            <li>• – 25 % du 21 au 30 avril</li>
                            <li>• – 20 % du 1er au 14 mai</li>
                            <li>• – 10 % du 15 au 31 mai</li>
                        </ul>
                        <button class="btn-offer">S'évader</button>
                    </div>
                </div>
            </div>
        </section>

        <!-- CHAMBRES -->
        <section id="rooms">
            <h2 class="section-title" data-aos="fade-up">Nos Sanctuaires</h2>
            <div class="rooms-grid">
                <div class="room-card" data-aos="fade-up">
                    <img src="/images/Guestroom_Double_Double_0003.jpg" alt="Chambre">
                    <div class="room-info">
                        <h3>Chambre Deluxe</h3>
                        <div class="price">25 000 DZD / Nuit</div>
                    </div>
                </div>
                <div class="room-card" data-aos="fade-up" data-aos-delay="200">
                    <img src="/images/Suite_Ambassador_Bed_9697.jpg" alt="Suite">
                    <div class="room-info">
                        <h3>Suite Ambassadeur</h3>
                        <div class="price">49 000 DZD / Nuit</div>
                    </div>
                </div>
                <div class="room-card" data-aos="fade-up" data-aos-delay="400">
                    <img src="/images/Suite_Royal_Bedroom_8956.jpg" alt="Royal">
                    <div class="room-info">
                        <h3>Suite Royale</h3>
                        <div class="price">90 000 DZD / Nuit</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- EXPLORE -->
        <section id="explore">
            <h2 class="section-title" data-aos="fade-up">Cité de l'Art & de l'Histoire</h2>
            <div class="explore-grid">
                <div class="explore-item" data-aos="zoom-in">
                    <img src="/images/Mansourah.png" alt="Mansourah">
                    <div class="explore-overlay">
                        <h3>Mansourah</h3>
                    </div>
                </div>
                <div class="explore-item" data-aos="zoom-in" data-aos-delay="200">
                    <img src="/images/palais.png" alt="Palais El mechouar">
                    <div class="explore-overlay">
                        <h3>Palais El mechouar</h3>
                    </div>
                </div>

                <div class="explore-item" data-aos="zoom-in" data-aos-delay="400">
                    <img src="/images/centre_etudes_andalouses.jpg" alt="Centre d'études andalouses">
                    <div class="explore-overlay">
                        <h3>Centre d'études andalouses</h3>
                    </div>
                </div>
            </div>
        </section>

        <!-- CONTACT -->
        <section id="contact">
            <div class="contact-container" data-aos="fade-up">
                <div class="contact-info">
                    <h3 style="font-family: var(--font-title); font-size: 32px; margin-bottom: 20px;">Conciergerie</h3>
                    <p><i class="fas fa-map-marker-alt"></i> Plateau Lalla Setti, Tlemcen, Algérie</p>
                    <p><i class="fas fa-phone"></i> <a href="tel:+21343401111"
                            style="color: inherit; text-decoration: none; transition: 0.3s; opacity: 0.8;"
                            onmouseover="this.style.opacity=1" onmouseout="this.style.opacity=0.8">+213 (0) 43 40 11
                            11</a></p>
                    <p style="margin-bottom: 30px;"><i class="fas fa-envelope"></i> <a
                            href="mailto:reservation@renaissancestlemcen.com"
                            style="color: inherit; text-decoration: none; transition: 0.3s; opacity: 0.8;"
                            onmouseover="this.style.opacity=1"
                            onmouseout="this.style.opacity=0.8">reservation@renaissancestlemcen.com</a></p>
                    <div class="social-links">
                        <a href="https://www.instagram.com/renaissancetlemcenhotel/" target="_blank"><i
                                class="fab fa-instagram"></i></a>
                        <a href="https://www.linkedin.com/company/renaissancetlemcenhotel/" target="_blank"><i
                                class="fab fa-linkedin-in"></i></a>
                    </div>
                </div>
                <div class="map-wrap">
                    <iframe
                        src="https://maps.google.com/maps?q=Renaissance%20Tlemcen&t=&z=14&ie=UTF8&iwloc=&output=embed"></iframe>
                </div>
            </div>
        </section>
    </main>

    <footer>RENAISSANCE TLEMCEN HOTEL — © 2026</footer>

    <!-- Scripts pour AOS et autres comportements -->
    <script is:inline src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            AOS.init({ duration: 1000, once: true });
        });

        const cursor = document.getElementById('cursor');
        const blur = document.getElementById('cursor-blur');
        let cursorActive = false;

        document.addEventListener('mousemove', e => {
            if (!cursorActive && window.innerWidth > 768) {
                document.body.classList.add('custom-cursor');
                if(cursor) cursor.style.opacity = '1';
                if(blur) blur.style.opacity = '1';
                cursorActive = true;
            }
            if(cursor && blur){
                cursor.style.transform = `translate3d(${e.clientX - 4}px, ${e.clientY - 4}px, 0)`;
                blur.style.transform = `translate3d(${e.clientX - 17}px, ${e.clientY - 17}px, 0)`;
            }
        });

        const header = document.getElementById('navbar');
        const heroBg = document.getElementById('hero-bg');

        let ticking = false;

        window.addEventListener('scroll', () => {
            if (!ticking) {
                window.requestAnimationFrame(() => {
                    const scroll = window.scrollY;
                    if (heroBg) heroBg.style.transform = `scale(${1.1 + scroll / 6000}) translateY(${scroll / 4}px)`;
                    if (scroll > 50) {
                        if(header) header.classList.add('scrolled');
                    } else {
                        if(header) header.classList.remove('scrolled');
                    }
                    ticking = false;
                });
                ticking = true;
            }
        });

        document.querySelectorAll('.offer-card').forEach(card => {
            card.addEventListener('click', () => {
                card.classList.toggle('active');
            });
        });
    </script>
</body>

</html>

<style is:global>
    :root {
        --bg: #051926;
        --accent: #ffffff;
        --cream: #f5e6c8;
        --glass: rgba(255, 255, 255, 0.05);
        --font-title: 'Cinzel', serif;
        --font-body: 'Montserrat', sans-serif;
        --transition: all 0.6s cubic-bezier(0.19, 1, 0.22, 1);
    }

    /* CURSEUR */
    #cursor {
        position: fixed;
        top: 0;
        left: 0;
        width: 8px;
        height: 8px;
        background: var(--cream);
        border-radius: 50%;
        pointer-events: none;
        z-index: 10000;
        opacity: 0;
        transition: opacity 0.3s;
    }

    #cursor-blur {
        position: fixed;
        top: 0;
        left: 0;
        width: 35px;
        height: 35px;
        border: 1px solid rgba(245, 230, 200, 0.4);
        border-radius: 50%;
        pointer-events: none;
        z-index: 9999;
        opacity: 0;
        transition: opacity 0.3s, border-color 0.15s ease-out;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body.custom-cursor,
    body.custom-cursor * {
        cursor: none !important;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        background: var(--bg);
        color: var(--accent);
        font-family: var(--font-body);
        overflow-x: hidden;
        line-height: 1.7;
    }

    /* NAV */
    header {
        position: fixed;
        top: 0;
        width: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 30px 60px;
        z-index: 1000;
        transition: var(--transition);
    }

    header.scrolled {
        padding: 15px 60px;
        background: rgba(5, 25, 38, 0.9);
        backdrop-filter: blur(15px);
    }

    .logo img {
        height: 100px;
        transition: var(--transition);
        filter: brightness(100);
    }

    header.scrolled .logo img {
        height: 70px;
    }

    nav ul {
        display: flex;
        list-style: none;
        gap: 30px;
    }

    nav ul li a {
        text-decoration: none;
        color: var(--accent);
        font-size: 11px;
        letter-spacing: 2px;
        text-transform: uppercase;
        opacity: 0.6;
        transition: 0.3s;
    }

    nav ul li a:hover {
        opacity: 1;
        color: var(--cream);
    }

    /* HERO */
    .hero {
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

    .hero-bg {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(to bottom, rgba(5, 25, 38, 0.3), var(--bg)), url('/images/Details_Exterior_Sunset_9649.jpg') center/cover;
        transform: scale(1.1);
        z-index: -1;
    }

    .hero h1 {
        font-family: var(--font-title);
        font-size: clamp(40px, 8vw, 90px);
        letter-spacing: 15px;
        text-transform: uppercase;
        text-align: center;
    }

    section {
        padding: 100px 10%;
    }

    .section-title {
        font-family: var(--font-title);
        font-size: clamp(30px, 4vw, 45px);
        text-align: center;
        margin-bottom: 60px;
        letter-spacing: 4px;
        color: var(--cream);
    }

    /* HISTOIRE */
    .about-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: center;
    }

    .about-text p {
        font-size: 18px;
        font-weight: 200;
        text-align: justify;
        margin-bottom: 25px;
    }

    .about-gallery {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    .about-gallery img {
        width: 100%;
        height: 250px;
        object-fit: cover;
        border-radius: 2px;
        filter: grayscale(0.3);
        transition: 0.5s;
    }

    .about-gallery img:hover {
        filter: grayscale(0);
        transform: scale(1.02);
    }

    /* SERVICES */
    .services-wrapper {
        position: relative;
        width: 100%;
    }

    .services-scroll-container {
        display: flex;
        overflow-x: auto;
        gap: 40px;
        padding: 20px 50px 60px 50px;
        scrollbar-width: none;
        -ms-overflow-style: none;
        scroll-behavior: smooth;
    }

    .services-scroll-container::-webkit-scrollbar {
        display: none;
    }

    .scroll-indicator {
        text-align: center;
        color: var(--cream);
        font-size: 12px;
        letter-spacing: 3px;
        margin-bottom: 20px;
        opacity: 0.6;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 15px;
    }

    .service-card-wide {
        min-width: 450px;
        background: var(--glass);
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: var(--transition);
        position: relative;
    }

    .service-card-wide:hover {
        transform: translateY(-10px);
        background: rgba(255, 255, 255, 0.1);
    }

    .service-card-wide img {
        width: 100%;
        height: 300px;
        object-fit: cover;
        opacity: 0.8;
        transition: 0.5s;
    }

    .service-card-wide:hover img {
        opacity: 1;
    }

    .service-card-content {
        padding: 30px;
    }

    .service-card-content h3 {
        font-family: var(--font-title);
        color: var(--cream);
        margin-bottom: 15px;
        font-size: 20px;
    }

    /* OFFRES */
    .offers-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 30px;
    }

    .offer-card {
        background: var(--glass);
        padding: 30px;
        border-radius: 2px;
        transition: var(--transition);
        border-top: 2px solid transparent;
        cursor: pointer !important;
    }

    .offer-card:hover {
        border-top-color: var(--cream);
        background: rgba(255, 255, 255, 0.08);
    }

    .offer-card img {
        width: 100%;
        height: 200px;
        object-fit: cover;
        margin-bottom: 20px;
    }

    .offer-details {
        max-height: 0;
        overflow: hidden;
        transition: 0.5s ease;
        opacity: 0;
    }

    .offer-card.active .offer-details {
        max-height: 500px;
        opacity: 1;
        padding-top: 20px;
    }

    .btn-offer {
        margin-top: 15px;
        background: none;
        border: 1px solid var(--cream);
        color: var(--cream);
        padding: 10px 20px;
        font-size: 10px;
        letter-spacing: 2px;
        text-transform: uppercase;
        transition: 0.3s;
    }

    .btn-offer:hover {
        background: var(--cream);
        color: var(--bg);
    }

    /* CHAMBRES */
    .rooms-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
    }

    .room-card {
        height: 600px;
        position: relative;
        overflow: hidden;
    }

    .room-card img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: 1.5s;
        filter: brightness(0.7);
    }

    .room-card:hover img {
        transform: scale(1.1);
        filter: brightness(1);
    }

    .room-info {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        padding: 40px;
        background: linear-gradient(transparent, rgba(5, 25, 38, 0.9));
    }

    .room-info h3 {
        font-family: var(--font-title);
        font-size: 22px;
    }

    .room-info .price {
        color: var(--cream);
        font-weight: 600;
        margin-top: 10px;
    }

    /* EXPLORE */
    .explore-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
    }

    .explore-item {
        position: relative;
        height: 450px;
        overflow: hidden;
    }

    .explore-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: 0.8s;
    }

    .explore-item:hover img {
        transform: scale(1.05);
    }

    .explore-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(5, 25, 38, 0.3);
        transition: 0.5s;
        text-align: center;
        padding: 20px;
    }

    .explore-overlay h3 {
        font-family: var(--font-title);
        font-size: 24px;
        letter-spacing: 3px;
        width: 100%;
    }

    /* CONTACT & SOCIAL */
    .contact-container {
        display: grid;
        grid-template-columns: 1fr 1.5fr;
        background: var(--cream);
        color: var(--bg);
        overflow: hidden;
    }

    .contact-info {
        padding: 60px;
    }

    .contact-info p {
        margin-bottom: 15px;
        word-wrap: break-word;
        /* Force le retour à la ligne pour l'email sur mobile */
        overflow-wrap: break-word;
    }

    .social-links {
        margin-top: 40px;
        display: flex;
        gap: 25px;
    }

    .social-links a {
        color: var(--bg);
        font-size: 20px;
        transition: 0.3s;
        opacity: 0.7;
    }

    .social-links a:hover {
        opacity: 1;
        transform: translateY(-3px);
    }

    .map-wrap {
        height: 450px;
    }

    iframe {
        width: 100%;
        height: 100%;
        border: none;
        filter: grayscale(1);
    }

    footer {
        text-align: center;
        padding: 50px;
        font-size: 11px;
        letter-spacing: 3px;
        opacity: 0.5;
    }

    /* RESPONSIVE DESIGN (ADAPTABILITÉ) */
    @media (max-width: 1024px) {
        header {
            padding: 20px 30px;
        }

        nav {
            display: none;
        }

        section {
            padding: 60px 5%;
        }

        .about-grid {
            grid-template-columns: 1fr;
            gap: 40px;
        }

        .rooms-grid {
            grid-template-columns: 1fr 1fr;
        }

        .explore-grid {
            grid-template-columns: 1fr 1fr;
        }

        .service-card-wide {
            min-width: 85vw;
        }
