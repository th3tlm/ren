---
---
<section id="rooms">
    <h2 class="section-title animate-on-scroll">Nos Sanctuaires</h2>
    <div class="rooms-grid">
        <div class="room-card animate-on-scroll">
            <img src="/images/Guestroom_Double_Double_0003.webp" alt="Chambre Deluxe" loading="lazy">
            <div class="room-info">
                <h3>Chambre Deluxe</h3>
                <div class="price">25 000 DZD / Nuit</div>
            </div>
        </div>
        <div class="room-card animate-on-scroll" style="transition-delay: 0.2s">
            <img src="/images/Suite_Ambassador_Bed_9697.webp" alt="Suite Ambassadeur" loading="lazy">
            <div class="room-info">
                <h3>Suite Ambassadeur</h3>
                <div class="price">49 000 DZD / Nuit</div>
            </div>
        </div>
        <div class="room-card animate-on-scroll" style="transition-delay: 0.4s">
            <img src="/images/Suite_Royal_Bedroom_8956.webp" alt="Suite Royale" loading="lazy">
            <div class="room-info">
                <h3>Suite Royale</h3>
                <div class="price">90 000 DZD / Nuit</div>
            </div>
        </div>
    </div>
</section>