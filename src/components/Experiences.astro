---
---
<section id="services" style="padding-right: 0; padding-left: 0;">
    <h2 class="section-title animate-on-scroll">Nos Expériences</h2>
    <div class="scroll-indicator">
        <i class="fas fa-chevron-left"></i> SWIPE <i class="fas fa-chevron-right"></i>
    </div>
    <div class="services-scroll-container animate-on-scroll">
        <div class="service-card-wide">
            <img src="/images/Spa_Massage_Room_0027.webp" alt="Spa" loading="lazy">
            <div class="service-card-content">
                <h3>Spa & Bien-être</h3>
                <p>Hammam traditionnel et rituels de soins ancestraux pour une sérénité absolue.</p>
            </div>
        </div>
        <div class="service-card-wide">
            <img src="/images/Restaurant_Arabesque_General_Seating_0019.webp" alt="Gastronomie" loading="lazy">
            <div class="service-card-content">
                <h3>Gastronomie</h3>
                <p>Découvrez nos 5 tables d'exception, entre saveurs locales et haute cuisine internationale.</p>
            </div>
        </div>
        <div class="service-card-wide">
            <img src="/images/Gym_0002.webp" alt="Fitness" loading="lazy">
            <div class="service-card-content">
                <h3>Fitness & Sport</h3>
                <p>Piscine et équipements de pointe avec une vue panoramique sur la ville.</p>
            </div>
        </div>
        <div class="service-card-wide">
            <img src="/images/Social_Ballroom_Setup_0004.webp" alt="Event" loading="lazy">
            <div class="service-card-content">
                <h3>Mariages & Gala</h3>
                <p>Des espaces majestueux et un service sur-mesure pour vos événements de prestige.</p>
            </div>
        </div>
        <div class="service-card-wide">
            <img src="/images/Patio_Lounge_Exterior_Lifestyle_7904.webp" alt="Lounge" loading="lazy">
            <div class="service-card-content">
                <h3>Lounge Extérieur</h3>
                <p>Détendez-vous sur notre terrasse avec une vue imprenable sur le coucher du soleil.</p>
            </div>
        </div>
    </div>
</section>